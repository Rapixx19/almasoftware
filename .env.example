# ============================================================
# ALMA · Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ─── SUPABASE (Client-side safe) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── SUPABASE (Server-only) ────────────────────────────────
# ⚠️ CRITICAL: Never expose service role key to client
SUPABASE_SERVICE_ROLE_KEY=

# ─── ANTHROPIC API ─────────────────────────────────────────
# Used for Claude integration
ANTHROPIC_API_KEY=

# ─── ELEVENLABS (Voice) ────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── TELEGRAM BOT ──────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ─── PWA PUSH NOTIFICATIONS ────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── SCRAPER DATABASE (Server-only) ────────────────────────
# Isolated Supabase project for web scraping data
# ⚠️ CRITICAL: Never expose to client
SCRAPER_SUPABASE_URL=
SCRAPER_SUPABASE_SERVICE_KEY=
